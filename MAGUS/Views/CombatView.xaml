<Window x:Class="MAGUS.Presentation.Views.CombatView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MAGUS.Presentation.ViewModels"
        xmlns:vm="clr-namespace:MAGUS.Presentation.ViewModels"
        xmlns:cvm="clr-namespace:MAGUS.Presentation.ViewModels"
        mc:Ignorable="d"
        Title="CombatView" Height="450" Width="800">
    
    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/Assets/Images/app_bg_2.jpg"></ImageBrush>
        </Grid.Background>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="70*"/>
            <ColumnDefinition Width="30*"/>
        </Grid.ColumnDefinitions>

        <Grid x:Name="CharacterStats">
            <Grid.RowDefinitions>
                <RowDefinition Height="20*"/>
                <RowDefinition Height="5*"/>
                <RowDefinition Height="75*"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal">
                <TextBlock Text="KÉ :" Height="30" Margin="10,30,10,30" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Hero.Ke}" Height="30" Margin="0,30,30,30" VerticalAlignment="Center" Background="LightBlue"/>
                <TextBlock Text="TÉ :" Height="30" Margin="10,30,10,30" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Hero.Te}" Height="30" Margin="0,30,30,30" VerticalAlignment="Center" Background="LightBlue"/>
                <TextBlock Text="Vé :" Height="30" Margin="10,30,10,30" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Hero.Ve}" Height="30" Margin="0,30,30,30" VerticalAlignment="Center" Background="LightBlue"/>
                <TextBlock Text="Cé :" Height="30" Margin="10,30,10,30" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Hero.Ce}" Height="30" Margin="0,30,30,30" VerticalAlignment="Center" Background="LightBlue"/>
            </StackPanel>
                
                <Grid Grid.Row="1" Margin="30,0,30,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0" Text="Név" Background="LightGray" />
                    <TextBlock Grid.Column="1" Text="KÉ" Background="LightGray"/>
                    <TextBlock Grid.Column="2" Text="TÉ/CÉ" Background="LightGray"/>
                    <TextBlock Grid.Column="3" Text="VÉ/Táv" Background="LightGray"/>
                    <TextBlock Grid.Column="4" Text="Sebzés" Background="LightGray"/>
                    <TextBlock Grid.Column="5" Text="Tám/kör" Background="LightGray"/>
                    
                </Grid>
                <ListBox Grid.Row="2" x:Name="WeaponList"  Margin="30,0,30,30"
                     ItemsSource="{Binding Hero.Weapons}"
                     SelectedItem="{Binding SelectedWeapon}">
                <ListBox.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#80493A25" Offset="0"/>
                        <GradientStop Color="#80785A20" Offset="1"/>
                    </LinearGradientBrush>
                </ListBox.Background>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Name}"/>
                            <TextBlock Text="{Binding Ke}"/>
                            <TextBlock Text="{Binding DisplayeAttack}"/>
                            <TextBlock Text="{Binding DisplayDefenseOrRange}"/>
                            <TextBlock Text="{Binding DamageToString}"/>
                            <TextBlock Text="{Binding Attacks}"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <Grid x:Name="Functions" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <Button x:Name="InitiativeButton" Command="{Binding MakeInitiativeCommand}" Content="Kezdeményező dobás" Height="25" 
                 Margin="20,50,30,5" BorderThickness="1" BorderBrush="Gold">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#80493A25" Offset="0"/>
                            <GradientStop Color="#80785A20" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>
                <TextBlock x:Name="initiativeResult" Text="{Binding InitiativeResult}" Margin="20,5,30,10" Height="50">
                    <TextBlock.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#80493A25" Offset="0"/>
                            <GradientStop Color="#80785A20" Offset="1"/>
                        </LinearGradientBrush>
                    </TextBlock.Background>
                </TextBlock>
            </StackPanel>

            <StackPanel Grid.Row="1">
                <Button x:Name="AttackButton" Command="{Binding MakeAttackCommand}" Content="Támadó dobás" Height="25" Margin="20,40,30,5" BorderThickness="1" BorderBrush="Gold">
                    <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#80493A25" Offset="0"/>
                        <GradientStop Color="#80785A20" Offset="1"/>
                    </LinearGradientBrush>
                    </Button.Background>
                </Button>
                <TextBlock x:Name="AttackResult" Text="{Binding AttackResult}" Margin="20,5,30,10" Height="50" >
                    <TextBlock.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#80493A25" Offset="0"/>
                            <GradientStop Color="#80785A20" Offset="1"/>
                        </LinearGradientBrush>
                    </TextBlock.Background>
                </TextBlock>
            </StackPanel>

            <StackPanel Grid.Row="2">
                <Button x:Name="DamageButton" Content="Sebzés dobás" Command="{Binding MakeDamageCommand}" Height="25" Margin="20,20,30,5" BorderThickness="1" BorderBrush="Gold">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#80493A25" Offset="0"/>
                            <GradientStop Color="#80785A20" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>
                <TextBlock x:Name="DamageResult" Text="{Binding DamageResult}" Margin="20,5,30,0" Height="50" >
                    <TextBlock.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#80493A25" Offset="0"/>
                            <GradientStop Color="#80785A20" Offset="1"/>
                        </LinearGradientBrush>
                    </TextBlock.Background>
                </TextBlock>
            </StackPanel>
            
            
            
            
            
            
        </Grid>

    </Grid>
</Window>
